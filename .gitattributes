# Normalize all text files to LF on commit and checkout, on every platform.

* text=auto eol=lf

# Belt-and-suspenders for files where execution or parsing depends on LF
*.md       text eol=lf
*.sh       text eol=lf
*.ps1      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.txt      text eol=lf
LICENSE    text eol=lf
NOTICE     text eol=lf

# Mark common binaries explicitly so Git does not try to normalize them
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.bmp      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.7z       binary
*.gz       binary
*.tar      binary
*.tgz      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
