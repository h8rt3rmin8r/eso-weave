<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX MSI source for ESO Weave, built by the pinned release pipeline with the
  cargo-wix no-build step (which resolves this file at the default wix/main.wxs
  location). It installs the single application binary under Program Files with a
  guided wizard (welcome, license, custom setup, progress, exit), a license
  acceptance gate, an always-installed Start Menu shortcut, an opt-in desktop
  shortcut (off by default), branded wizard artwork, the application icon, and an
  optional de-elevated launch on finish. It supports add and remove and upgrade in
  place, and never writes to game or Documents directories.

  cargo-wix supplies the $(var.Version) and $(var.CargoTargetBinDir) definitions.

  Pinned artifact. Change it only with a dated decision recorded in CHANGELOG.md.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="ESO Weave"
    UpgradeCode="B7A5F0E2-1C3D-4E6A-9B2F-8D4C5A6E7F10"
    Manufacturer="ESO Weave"
    Language="1033"
    Codepage="1252"
    Version="$(var.Version)">

    <Package
      Id="*"
      Keywords="Installer"
      Description="ESO Weave desktop companion for The Elder Scrolls Online"
      Manufacturer="ESO Weave"
      InstallerVersion="450"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      SummaryCodepage="1252" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of ESO Weave is already installed. Setup will now exit." />

    <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1" />
    <Property Id="DiskPrompt" Value="ESO Weave Installation" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder" Name="PFiles">
        <Directory Id="APPLICATIONFOLDER" Name="ESO Weave">
          <Component Id="ApplicationBinary" Guid="*" Win64="yes">
            <File
              Id="EsoWeaveExe"
              Name="eso-weave.exe"
              DiskId="1"
              Source="$(var.CargoTargetBinDir)\eso-weave.exe"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="ESO Weave" />
      </Directory>

      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*" Win64="yes">
        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="ESO Weave"
          Description="Desktop companion for The Elder Scrolls Online"
          Target="[#EsoWeaveExe]"
          WorkingDirectory="APPLICATIONFOLDER"
          Icon="ProductIcon" />
        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\ESO Weave\ESO Weave"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="DesktopFolder">
      <Component Id="ApplicationDesktopShortcut" Guid="*" Win64="yes">
        <Shortcut
          Id="ApplicationDesktopShortcutLink"
          Name="ESO Weave"
          Description="Desktop companion for The Elder Scrolls Online"
          Target="[#EsoWeaveExe]"
          WorkingDirectory="APPLICATIONFOLDER"
          Icon="ProductIcon" />
        <RegistryValue
          Root="HKCU"
          Key="Software\ESO Weave\ESO Weave"
          Name="desktop_shortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Icon Id="ProductIcon" SourceFile="assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />

    <!--
      Installer UI: a WixUI_FeatureTree wizard with a license acceptance gate and
      a Custom Setup step. The desktop shortcut is its own feature, off by default
      (Level 2), so the user opts in rather than being given one unasked; the
      application (with its Start Menu shortcut) cannot be deselected. The install
      location is set through the Custom Setup Browse button. The license text is
      the repository Apache-2.0 license rendered as clean proportional RTF, and the
      wizard uses branded banner and dialog artwork.
    -->
    <WixVariable Id="WixUILicenseRtf" Value="packaging\windows\License.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="packaging\windows\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="packaging\windows\dialog.bmp" />
    <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />
    <UIRef Id="WixUI_FeatureTree" />

    <!--
      Optional "Launch ESO Weave" checkbox on the exit dialog, checked by default.
      The ExitDialog runs in the InstallUISequence as the invoking (non-elevated)
      user, so WixShellExec launches the application de-elevated. A silent install
      has no UI sequence, so it never launches. The NOT Installed guard restricts
      the launch to fresh installs.
    -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch ESO Weave" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#EsoWeaveExe]" />
    <CustomAction
      Id="LaunchApplication"
      BinaryKey="WixCA"
      DllEntry="WixShellExec"
      Impersonate="yes" />
    <UI>
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchApplication">WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed</Publish>
    </UI>

    <Feature
      Id="Application"
      Title="ESO Weave"
      Level="1"
      Absent="disallow"
      ConfigurableDirectory="APPLICATIONFOLDER"
      Description="The ESO Weave application and its Start Menu shortcut.">
      <ComponentRef Id="ApplicationBinary" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>
    <!--
      The desktop shortcut is opt-in: Level 2 means it is not installed unless the
      user selects it in the Custom Setup step. This is why the Component carries
      its own HKCU key path rather than living in the always-installed feature.
    -->
    <Feature
      Id="DesktopShortcut"
      Title="Desktop shortcut"
      Level="2"
      Description="Create a shortcut to ESO Weave on the desktop.">
      <ComponentRef Id="ApplicationDesktopShortcut" />
    </Feature>
  </Product>
</Wix>
